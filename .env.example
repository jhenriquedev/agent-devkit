# Azure DevOps
# AZURE_DEVOPS_ORG aceita o slug da organizacao ou a URL https://dev.azure.com/<org>.
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PAT=
# Opcional. Padrao interno: 7.1.
AZURE_DEVOPS_API_VERSION=
# Opcional. Use apenas como fallback local; prefira passar --project nos comandos.
AZURE_DEVOPS_PROJECT=

# TOPdesk
TOPDESK_BASE_URL=
TOPDESK_USERNAME=
# Preferencial: application password do TOPdesk.
TOPDESK_APP_PASSWORD=
# Fallback local legado, aceito por compatibilidade.
TOPDESK_PASSWORD=
# Opcional. Escritas continuam exigindo --execute nos runners.
TOPDESK_ALLOW_RAW_MUTATIONS=

# AWS CloudWatch
AWS_PROFILE=
AWS_REGION=
AWS_DEFAULT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Elasticsearch
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
ELASTIC_API_KEY=
EC_API_KEY=
ELASTICSEARCH_DEFAULT_TIME_FIELD=@timestamp

# Bancos e servicos externos usados por futuros agentes/capabilities.
POSTGRES_DB_CONN_STRING=
POSTGRES_STATEMENT_TIMEOUT=15000
POSTGRES_LOCK_TIMEOUT=5000
POSTGRES_QUERY_LIMIT=100

# SQL Server
SQLSERVER_DB_CONN_STRING=
SQLSERVER_STATEMENT_TIMEOUT=15000
SQLSERVER_LOCK_TIMEOUT=5000
SQLSERVER_QUERY_LIMIT=100
SQLSERVER_MAX_AFFECTED_ROWS=100
SQLSERVER_CHANGE_SCHEMA=ai_devkit

# Technical Integration Analyst
TECH_INTEGRATION_DEFAULT_BASE_URL=
TECH_INTEGRATION_DEFAULT_AUTH_TOKEN=
TECH_INTEGRATION_HTTP_TIMEOUT=30

# BPO Analyser
BPO_SERVICO_API_URL=
BPO_WS_PROPOSTA_URL=
BPO_WS_ESTEIRA_URL=
BPO_WS_FORMALIZACAO_URL=
BPO_CONSIGNACAO_URL=
BPO_CARTAO_USER=
BPO_CARTAO_PASSWORD=
BPO_HTTP_TIMEOUT=30
BPO_DEFAULT_DOCUMENT_TYPE=Nao_Definido
BPO_TLS_VERIFY=true
BPO_ELIGIBLE_SITUATIONS=INT,INTEGRADA,APR,APROVADA
BPO_ELIGIBLE_PROPOSAL_TYPES=3
BPO_REQUIRE_POSITIVE_WITHDRAW_LIMIT=true
BPO_FORBIDDEN_URL_PATTERNS=
BPO_PARTNER_CONTRACT_FIELDS=
BPO_ORIGINATOR_CONTRACT_FIELDS=

# Figma UI/UX Product Designer
# O CLI local precisa de um bridge para executar MCP/Figma de verdade.
FIGMA_MCP_ENABLED=false
FIGMA_DIRECT_MODE=false
FIGMA_MCP_BRIDGE_COMMAND=
FIGMA_MCP_BRIDGE_TIMEOUT_SECONDS=120
FIGMA_DEFAULT_PLAN_KEY=
FIGMA_DEFAULT_PROJECT_ID=
