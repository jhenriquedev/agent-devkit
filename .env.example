# Azure DevOps
# AZURE_DEVOPS_ORG aceita o slug da organizacao ou a URL https://dev.azure.com/<org>.
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PAT=
# Opcional. Padrao interno: 7.1.
AZURE_DEVOPS_API_VERSION=
# Opcional. Use apenas como fallback local; prefira passar --project nos comandos.
AZURE_DEVOPS_PROJECT=

# TOPdesk
TOPDESK_BASE_URL=
TOPDESK_USERNAME=
# Preferencial: application password do TOPdesk.
TOPDESK_APP_PASSWORD=
# Fallback local legado, aceito por compatibilidade.
TOPDESK_PASSWORD=
# Opcional. Escritas continuam exigindo --execute nos runners.
TOPDESK_ALLOW_RAW_MUTATIONS=

# AWS CloudWatch
AWS_PROFILE=
AWS_REGION=
AWS_DEFAULT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Bancos e servicos externos usados por futuros agentes/capabilities.
POSTGRES_DB_CONN_STRING=

ELASTIC_API_KEY=
