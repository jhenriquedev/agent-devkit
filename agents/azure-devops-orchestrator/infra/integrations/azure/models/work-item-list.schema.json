{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Azure DevOps Work Item List",
  "type": "object",
  "required": ["count", "items", "wiql"],
  "properties": {
    "count": { "type": "integer" },
    "items": {
      "type": "array",
      "items": { "$ref": "work-item.schema.json" }
    },
    "wiql": { "type": "string" }
  },
  "additionalProperties": false
}
